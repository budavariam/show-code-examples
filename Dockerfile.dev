FROM node:24-alpine

WORKDIR /app

# Install deps as a separate layer so they are cached when only source changes
COPY package*.json ./
RUN npm ci

EXPOSE 8080
CMD sh -c "\
  ln -sf /app/docs /app/show-code-examples && \
  ./node_modules/.bin/webpack --watch --config webpack.config.js & \
  ./node_modules/.bin/http-server -p 8080 -c-1 . \
"
